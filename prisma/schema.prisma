// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



model admin_users {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model live_sessions {
  id                  String          @id @default(uuid())
  title               String
  video_id            String
  video               videos          @relation(fields: [video_id], references: [id])
  context_text        String?
  ai_tone             String          @default("friendly")
  status              String          @default("IDLE") // IDLE, LIVE, STOPPED
  viewer_count        Int             @default(0)
  youtube_video_id    String?         // YouTube Video ID for chat polling (e.g. "dQw4w9WgXcQ")
  youtube_channel_id  String?         // Optional: YouTube Channel ID
  target_rtmp_url     String?         // External RTMP Server URL (e.g. rtmp://a.rtmp.youtube.com/live2)
  stream_key          String?         // External Stream Key
  loop_mode           String          @default("infinite") // "infinite" | "count"
  loop_count          Int?            // Total playback count when loop_mode = "count"
  
  // Schedule Configuration
  schedule_enabled        Boolean        @default(false)
  schedule_type           String         @default("one-time") // "one-time" | "repeat"
  
  // One-time Schedule
  schedule_start_at       DateTime?      // Tanggal & waktu mulai (one-time)
  schedule_end_at        DateTime?      // Tanggal & waktu selesai (one-time)
  
  // Repeat Schedule
  schedule_days          String?        // JSON array: ["monday","tuesday"]
  schedule_start_time   String?        // Format HH:mm (misal: "10:00")
  schedule_end_time     String?        // Format HH:mm (misal: "18:00")
  schedule_timezone    String         @default("Asia/Jakarta")
  
  // Repeat Options
  schedule_repeat_end    DateTime?      // Kapan repeat berhenti (opsional)
  
  // Status
  last_scheduled_run     DateTime?      // Last time schedule ran
  
  created_at          DateTime        @default(now())
  updated_at          DateTime        @updatedAt
  chat_logs           chat_logs[]
  ai_reply_logs       ai_reply_logs[]
  schedules            session_schedules[]
}


model videos {
  id               String          @id @default(uuid())
  filename         String
  file_path        String
  file_type        String
  file_size        BigInt?
  storage_provider String          @default("local")
  storage_key      String?
  public_url       String?
  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt
  sessions         live_sessions[]
}


model context_documents {
  id         String   @id @default(uuid())
  title      String
  content    String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model chat_logs {
  id              String        @id @default(uuid())
  live_session_id String
  viewer_id       String
  message         String
  created_at      DateTime      @default(now())
  live_session    live_sessions @relation(fields: [live_session_id], references: [id], onDelete: Cascade)
}

model ai_reply_logs {
  id              String        @id @default(uuid())
  live_session_id String
  chat_id         String?
  prompt          String
  reply           String
  audio_url       String?
  created_at      DateTime      @default(now())
  live_session    live_sessions @relation(fields: [live_session_id], references: [id], onDelete: Cascade)
}

// Multi-Schedule Support: Separate table for multiple schedules per session
model session_schedules {
  id              String        @id @default(uuid())
  live_session_id String
  live_session    live_sessions @relation(fields: [live_session_id], references: [id], onDelete: Cascade)
  
  // Schedule Type
  schedule_type   String        @default("one-time") // "one-time" | "repeat"
  
  // One-time Schedule
  scheduled_at    DateTime?     // Specific date & time for one-time
  scheduled_end_at DateTime?    // End date & time for one-time
  
  // Repeat Schedule  
  days_of_week    String?       // JSON array: ["monday","tuesday"]
  start_time      String?       // Format HH:mm (e.g. "10:00")
  end_time        String?       // Format HH:mm (e.g. "18:00")
  
  // Common
  timezone        String        @default("Asia/Jakarta")
  active          Boolean       @default(true)
  repeat_end_date DateTime?     // When repeat schedule ends (optional)
  
  // Status tracking
  last_run        DateTime?     // Last time this schedule ran
  
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt
}

model system_settings {
  id                    String   @id @default("1")
  openai_api_key        String?
  gemini_api_key        String?
  ai_provider           String   @default("openai")
  tts_provider          String   @default("openai")
  yt_channel_handle     String?
  tiktok_channel_handle String?
  ai_name               String   @default("Loop")
  ai_persona            String?  @db.Text
  ai_tone_default       String   @default("friendly")
  mediamtx_host         String   @default("localhost")
  rtmp_port             Int      @default(1935)
  hls_port              Int      @default(8888)
  redis_url             String   @default("redis://localhost:6379")
  max_response_length   Int      @default(150)
  yt_cookie             String?
  app_base_url          String   @default("http://localhost:3000")
  scheduler_api_key     String   @default("looplive-scheduler-internal-key")
  updated_at            DateTime @updatedAt
}

model sound_events {
  id         String   @id @default(uuid())
  event_type String   // "keyword" or "join"
  keyword    String?  // The keyword to trigger the sound (e.g. "hai")
  audio_url  String   // Path to the audio file in public/sounds/
  active     Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

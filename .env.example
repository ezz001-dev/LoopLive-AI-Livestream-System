# Database Connection
DATABASE_URL="postgresql://looplive_user:looplive_password@127.0.0.1:5433/looplive_db"

# JWT Secret
JWT_SECRET="change-me-in-production"

# AI Providers
OPENAI_API_KEY=""
GEMINI_API_KEY=""
AI_PROVIDER="openai"
TTS_PROVIDER="openai"

# Redis
REDIS_URL="redis://localhost:6379"

# Email Configuration (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your_gmail@gmail.com"
SMTP_PASS="xxxx xxxx xxxx xxxx"    # Gmail App Password (bukan password biasa)
SMTP_FROM="LoopLive <your_gmail@gmail.com>"

# YouTube Live Auto-Detect
YT_CHANNEL_HANDLE="@yourchannel"
YT_COOKIE=""

# Internal Access Gate
# Recommended for internal admin behind Cloudflare Zero Trust:
# INTERNAL_ACCESS_MODE="proxy_header"
# INTERNAL_AUTH_PROXY_HEADER="cf-access-authenticated-user-email"
# INTERNAL_AUTH_PROXY_VALUE=""
#
# Modes:
# disabled      -> hanya pakai login app
# ip_whitelist  -> whitelist exact IP via ALLOWED_IPS
# tailscale     -> hanya izinkan IP private/Tailscale (10.x, 172.16-31.x, 192.168.x, 100.64-127.x)
# proxy_header  -> percaya header dari reverse proxy / Zero Trust gateway
INTERNAL_ACCESS_MODE="proxy_header"
ALLOWED_IPS=""
INTERNAL_AUTH_PROXY_HEADER="cf-access-authenticated-user-email"
INTERNAL_AUTH_PROXY_VALUE=""

# Cloudflare R2 Storage
STORAGE_PROVIDER="r2"
R2_ACCESS_KEY_ID=6bd2df1dea2136bb9537ac232c30675e
R2_SECRET_ACCESS_KEY=e21a279610e9841d556b3df650d9a400426a504d83491638abc82c8d649274ed
R2_ENDPOINT=https://860d3ed3edbae07a7dc2421402ce4b71.r2.cloudflarestorage.com
R2_BUCKET_NAME=fluxo
R2_PUBLIC_URL=https://images.fluxo-ai.pro


# Optional: use signed read URLs for FFmpeg instead of public bucket URLs
R2_SIGNED_READS="false"
R2_SIGNED_READ_TTL_SECONDS="43200"

# FFmpeg Streaming Profile
FFMPEG_VIDEO_CODEC="libx264"
FFMPEG_PRESET="veryfast"
FFMPEG_TUNE="zerolatency"
FFMPEG_PIXEL_FORMAT="yuv420p"
FFMPEG_FPS="30"
FFMPEG_GOP="60"
FFMPEG_VIDEO_BITRATE="2500k"
FFMPEG_MAXRATE="2500k"
FFMPEG_BUFSIZE="5000k"
FFMPEG_AUDIO_CODEC="aac"
FFMPEG_AUDIO_RATE="44100"
FFMPEG_AUDIO_CHANNELS="2"
FFMPEG_AUDIO_BITRATE="128k"
FFMPEG_MAX_RESTART_ATTEMPTS="10"
FFMPEG_RESTART_DELAY_MS="5000"
FFMPEG_MAX_RESTART_DELAY_MS="60000"

# Audio Event Queue
AUDIO_EVENT_QUEUE_PREFIX="audio_event_queue"

# Stream Audio Mixing
STREAM_AUDIO_DUCKING_ENABLED="true"
STREAM_AUDIO_DUCKING_LEVEL="0.35"
STREAM_AUDIO_EVENT_GAIN="1.0"
STREAM_AUDIO_MAIN_GAIN="1.0"
STREAM_AUDIO_EVENT_FADE_IN_SECONDS="0.12"
STREAM_AUDIO_EVENT_FADE_OUT_SECONDS="0.18"

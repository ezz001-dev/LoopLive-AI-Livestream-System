# Database Connection
DATABASE_URL="postgresql://looplive_user:looplive_password@127.0.0.1:5433/looplive_db"

# JWT Secret
JWT_SECRET="change-me-in-production"

# AI Providers
OPENAI_API_KEY=""
GEMINI_API_KEY=""
AI_PROVIDER="openai"
TTS_PROVIDER="openai"

# Redis
REDIS_URL="redis://localhost:6379"

# YouTube Live Auto-Detect
YT_CHANNEL_HANDLE="@yourchannel"
YT_COOKIE=""

# IP Whitelisting (Optional)
ALLOWED_IPS=""

# Cloudflare R2 Storage
STORAGE_PROVIDER="local"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_BUCKET_NAME=""
R2_PUBLIC_URL="https://<public-bucket-domain>"

# Optional: use signed read URLs for FFmpeg instead of public bucket URLs
R2_SIGNED_READS="false"
R2_SIGNED_READ_TTL_SECONDS="43200"
